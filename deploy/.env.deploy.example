# ExcelManus 部署配置模板
# 复制为 .env.deploy 并填入实际值：
#   cp .env.deploy.example .env.deploy
#
# 注意：.env.deploy 已在 .gitignore 中，不会被提交到仓库。

# ── 服务器地址 ──
BACKEND_SERVER=your.backend.server.ip
FRONTEND_SERVER=your.frontend.server.ip

# ── SSH 配置 ──
SERVER_USER=root
# SSH 密钥文件名（相对于项目根目录）
BACKEND_SSH_KEY_NAME=your_backend_key.pem
FRONTEND_SSH_KEY_NAME=your_frontend_key.pem

# ── 远程路径 ──
BACKEND_REMOTE_DIR=/www/wwwroot/excelmanus
FRONTEND_REMOTE_DIR=/www/wwwroot/excelmanus

# ── Node.js（前端服务器） ──
FRONTEND_NODE_BIN=/usr/local/bin

# ── Git 仓库 ──
REPO_URL=https://gitee.com/kilolonion/excelmanus.git
REPO_BRANCH=main

# ── 可选：站点 URL（用于健康检查和 BACKEND_ORIGIN 自动修复） ──
# SITE_URL=https://your-domain.com
# SITE_URLS=https://domain1.com,https://domain2.com

# ── 可选：前端运行时后端地址（Docker 场景推荐） ──
# 无需重新构建前端镜像即可更改后端地址。
# 留空 → 回退到构建时的 NEXT_PUBLIC_BACKEND_ORIGIN 或自动探测
# "same-origin" → 通过 Nginx 反代（生产推荐）
# "http://backend:8000" → 直连指定后端
# EXCELMANUS_RUNTIME_BACKEND_ORIGIN=same-origin

# ── 可选：高级部署模式 ──
# BACKEND_BLUEGREEN=false
# BACKEND_CANDIDATE_PORT=8001
# BACKEND_DRAIN_SECONDS=30
# BACKEND_CANARY=false
# CANARY_STEPS=10,50,100
# CANARY_OBSERVE_SECONDS=60
